# Required: a folder that lives inside your Google Drive desktop-sync location.
# The scraper writes <hash>.mp3 and <hash>.json files here; the cloud app reads
# from the same folder (via your own Drive sync on the cloud machine).
#
# Write the path verbatim — do NOT escape spaces with backslashes (.env is not a shell).
# If you prefer, you may wrap the path in double quotes.
OUTPUT_DIR=

# Optional: only consider notebooks modified on/after this date on the first run.
# After the first successful scrape, scraper_state.json takes over.
INITIAL_SINCE_DATE=

# Optional override: scrape this specific notebook instead of auto-picking the newest.
# Mostly useful for testing. Leave empty in production.
NOTEBOOK_URL=

# Optional: Playwright persistent user-data directory.
# Defaults to ./playwright_profile next to scraper.py.
# Do NOT point this at a live Chrome profile — Chrome locks it while running.
USER_DATA_DIR=

# Optional: prefix used to build episode titles. The notebook title is appended.
TITLE_PREFIX=NotebookLM Overview

# Optional: extra wait (ms) after navigation for the React UI to settle.
EXTRA_SETTLE_MS=2500

# -----------------------------------------------------------------------------
# M4A → MP3 conversion (convert.py + first post-scrape pass in scraper.py)
# -----------------------------------------------------------------------------
# Requires ffmpeg on PATH (e.g. `brew install ffmpeg`). Output filename is
# md5(m4a-bytes).mp3 so conversion is idempotent across reruns.

# Optional: libmp3lame VBR quality. 0 = best/largest, 9 = worst/smallest.
# 2 ≈ 190 kbps avg, well above transparent for voice.
MP3_QUALITY=2

# -----------------------------------------------------------------------------
# Transcription (transcribe.py + post-scrape pass in scraper.py)
# -----------------------------------------------------------------------------
# Runs locally on Apple Silicon via MLX Whisper. The model is downloaded from
# the Hugging Face Hub on first use and cached in ~/.cache/huggingface.

# Optional: Whisper model to use (HF repo or local path).
# Other good picks: mlx-community/whisper-medium-mlx, mlx-community/whisper-tiny-mlx.
WHISPER_MODEL=mlx-community/whisper-large-v3-mlx

# Optional: force a language (ISO-639-1, e.g. "en" or "de"). Empty = auto-detect.
WHISPER_LANGUAGE=

# Optional: short, well-punctuated priming sentence Whisper conditions on for
# the first window. This nudges the model to emit proper capitalisation and
# punctuation throughout the file. Defaults to a generic podcast intro.
# Leave empty to disable priming entirely.
WHISPER_INITIAL_PROMPT=

# -----------------------------------------------------------------------------
# Cover art (coverart.py + post-transcription pass in scraper.py)
# -----------------------------------------------------------------------------
# Uses a local/remote Ollama instance running an image-generation model
# (e.g. FLUX.2 Klein). No API key required.

# Base URL of the Ollama server. Point this at a remote host on your LAN/VPN
# if Ollama runs on a beefier machine.
OLLAMA_BASE_URL=http://localhost:11434

# Image-generation model to run on the Ollama host.
OLLAMA_IMAGE_MODEL=x/flux2-klein:9b

# -----------------------------------------------------------------------------
# Summarisation of manually-dropped MP3s (summarize.py + post-transcription
# pass in scraper.py). Only runs for MP3s that lack a sidecar JSON, so it's a
# no-op for episodes the scraper itself downloaded.
# -----------------------------------------------------------------------------
# Text-generation model to run on the Ollama host. Anything with good
# summarisation + JSON-mode support works; the default is the model the
# Mac Mini host happens to have loaded.
OLLAMA_TEXT_MODEL=charaf/qwen3.6-35b-a3b-coding-nvfp4-mlx:latest

# Optional: HTTP timeout for the /api/generate summarisation call (seconds).
# Long transcripts on a cold model load can take a while.
SUMMARY_TIMEOUT_S=600

# Optional: output dimensions and diffusion steps. Defaults are small/fast
# (~2 min per cover on FLUX.2 Klein 9B). Bump to 1024/20 for cover-art that
# meets Apple Podcasts' 1400×1400 spec — expect 10×+ longer generation.
COVER_WIDTH=1024
COVER_HEIGHT=1024
COVER_STEPS=20

# Optional: HTTP timeout for the /api/generate call (seconds). Image gen on a
# cold model load can take several minutes; bump this if you hit timeouts.
COVER_TIMEOUT_S=900

# Optional: override the global style prompt that every cover image is built on
# top of. Leave empty to use the bundled default (deep-indigo / amber editorial
# flat-vector look). The episode description is appended as thematic input.
COVER_STYLE_PROMPT=

# -----------------------------------------------------------------------------
# ID3 verification (id3tag.py + final post-scrape pass in scraper.py)
# -----------------------------------------------------------------------------
# After cover-art generation we verify every MP3 in OUTPUT_DIR carries the
# standard podcast ID3v2 tag set (TIT2, TPE1, TALB, TCON, TDRC, COMM, TDES,
# TGID, PCST, optional WFED, APIC). Missing or stale frames are rewritten;
# files that are already complete are left untouched.

# Optional: artist/host (TPE1). Default: "NotebookLM".
PODCAST_AUTHOR=NotebookLM

# Optional: album / show name (TALB). Defaults to TITLE_PREFIX above so all
# episodes appear under one show in podcatchers.
PODCAST_ALBUM=

# Optional: ID3 genre (TCON). "Podcast" is what iTunes/Apple Podcasts expect.
PODCAST_GENRE=Podcast

# Optional: the URL of the RSS feed (WFED). Set this to your FEED_BASE_URL +
# "/feed.xml" if you want Apple Podcasts to recognise the file as part of a
# specific feed. Leave empty to omit the frame.
PODCAST_FEED_URL=
