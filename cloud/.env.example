# Required: the folder containing the *.mp3 (and optional *.json sidecar)
# files written by the local scraper. On the cloud host this is typically the
# Google Drive desktop-sync mount, the same path your local box writes to.
#
# Write the path verbatim — do NOT escape spaces with backslashes (.env is not
# a shell). If you prefer, you may wrap the path in double quotes.
OUTPUT_DIR=

# Required: the public URL where THIS FastAPI app is reachable (no trailing
# slash). Used to build podcast enclosure URLs (→ /audio/<file>.mp3) and the
# atom:link self-reference (→ /feed.xml).
# Examples:
#   https://podcasts.example.com
#   https://notebooklm.example.net
FEED_BASE_URL=

# Optional: channel-level metadata shown by podcast clients.
FEED_TITLE=NotebookLM Audio Overviews
FEED_DESCRIPTION=Personal podcast feed of Google NotebookLM Audio Overviews.
FEED_AUTHOR=NotebookLM
FEED_OWNER_EMAIL=
FEED_LANGUAGE=en-us
FEED_CATEGORY=Technology

# Optional: show-level cover-art URL (1400x1400+ PNG recommended by Apple).
# Drop a `cover.png` into OUTPUT_DIR and set this to
#   ${FEED_BASE_URL}/images/cover.png
FEED_IMAGE_URL=

# Optional: human-facing site URL for the show. Defaults to FEED_BASE_URL.
FEED_LINK=
