# Required: a folder that lives inside your Google Drive desktop-sync location.
# The scraper writes <hash>.mp3 and <hash>.json files here.
#
# Write the path verbatim — do NOT escape spaces with backslashes (.env is not a shell).
# If you prefer, you may wrap the path in double quotes.
OUTPUT_DIR=

# Optional: only consider notebooks modified on/after this date on the first run.
# After the first successful scrape, scraper_state.json takes over.
INITIAL_SINCE_DATE=

# Optional override: scrape this specific notebook instead of auto-picking the newest.
# Mostly useful for testing. Leave empty in production.
NOTEBOOK_URL=

# Optional: Playwright persistent user-data directory.
# Defaults to ./playwright_profile next to scraper.py.
# Do NOT point this at a live Chrome profile — Chrome locks it while running.
USER_DATA_DIR=

# Optional: prefix used to build episode titles. The notebook title is appended.
TITLE_PREFIX=NotebookLM Overview

# Optional: extra wait (ms) after navigation for the React UI to settle.
EXTRA_SETTLE_MS=2500

# -----------------------------------------------------------------------------
# RSS feed generation (feed.py + auto-refresh from scraper.py)
# -----------------------------------------------------------------------------

# Required (for the feed): the public URL prefix under which OUTPUT_DIR is
# served. The script builds enclosure URLs as f"{FEED_BASE_URL}/{audio_file}".
# Leave empty to disable feed generation entirely.
# Examples:
#   https://podcasts.example.com
#   https://cdn.example.net/notebooklm
FEED_BASE_URL=

# Optional: the filename of the feed inside OUTPUT_DIR.
FEED_FILE=feed.xml

# Optional: channel-level metadata shown by podcast clients.
FEED_TITLE=NotebookLM Audio Overviews
FEED_DESCRIPTION=Personal podcast feed of Google NotebookLM Audio Overviews.
FEED_AUTHOR=NotebookLM
FEED_OWNER_EMAIL=
FEED_LANGUAGE=en-us
FEED_CATEGORY=Technology

# Optional: cover-art URL (1400x1400+ PNG/JPG recommended for podcast directories).
FEED_IMAGE_URL=

# Optional: human-facing site URL for the show. Defaults to FEED_BASE_URL.
FEED_LINK=

# -----------------------------------------------------------------------------
# Transcription (transcribe.py + post-scrape pass in scraper.py)
# -----------------------------------------------------------------------------

# Required to enable transcription. Leave empty to skip the pass entirely.
# Get a key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Optional: which Gemini model to use. Defaults to gemini-2.5-flash.
GEMINI_MODEL=gemini-2.5-flash
